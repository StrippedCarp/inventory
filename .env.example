# Database Configuration
DATABASE_URL=sqlite:///inventory.db
# For PostgreSQL: postgresql://user:password@localhost:5432/inventory_db

# Flask Configuration
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
FLASK_ENV=development

# Email Configuration (Gmail Example)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com

# SMS Configuration - Africa's Talking (Recommended for Kenya)
AT_USERNAME=your-africastalking-username
AT_API_KEY=your-africastalking-api-key
AT_SENDER_ID=INVENTORY

# SMS Configuration - Twilio (Alternative)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ML Model Configuration
ML_MODEL_PATH=ml/models/best_forecaster.pkl
ML_TRAINING_ENABLED=true

# Application Settings
APP_NAME=Inventory Management System
APP_URL=http://localhost:3000
CURRENCY=KES
TIMEZONE=Africa/Nairobi

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379/0

# InfluxDB Configuration (Optional - for time-series data)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=inventory

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
